{{- /* H-1: Bitwarden item UUID は公開リポジトリに混入させず、初回のみユーザーに
       問い合わせて `~/.config/chezmoi/chezmoi.toml` のローカル data に保存する。
       このファイルは `chezmoi init` 時にのみ評価され、`~/.config/chezmoi/chezmoi.toml`
       を生成する。`apply` 時の deploy ターゲットではないため `promptStringOnce` が使える。
       新しいデータを追加した後は再度 `chezmoi init` を実行する。 */ -}}
{{- /* 入力するのは Bitwarden item の UUID (例: eaefa7ca-...)。
       OpenRouter のキー本体ではない。キー本体は item 内の CODEX フィールドから
       apply 時に bitwardenFields で取得する。 */ -}}
{{- $bwOpenRouterItemId := promptStringOnce . "bitwardenOpenRouterItemId" "Bitwarden item UUID (NOT the key itself) whose CODEX field holds the OpenRouter API key" -}}
{{- /* 同様に Moonshot (Kimi) の API キーは item (platform.kimi.ai) の main フィールドから取得する。
       未入力 (空) のままなら Kimi ラッパーは定義されない (private_secrets.zsh.tmpl 側で gate)。 */ -}}
{{- $bwMoonshotItemId := promptStringOnce . "bitwardenMoonshotItemId" "Bitwarden item UUID (NOT the key itself) whose 'main' field holds the Moonshot/Kimi API key (leave empty to skip)" -}}

{{ if eq .chezmoi.os "windows" }}
[cd]
    command = "nu"
{{ else if eq .chezmoi.os "linux" }}
[hooks.read-source-state.pre]
    command = ".local/share/chezmoi/.executable_password_manager.sh"
{{ end }}

[data]
bitwardenOpenRouterItemId = {{ $bwOpenRouterItemId | quote }}
bitwardenMoonshotItemId = {{ $bwMoonshotItemId | quote }}
