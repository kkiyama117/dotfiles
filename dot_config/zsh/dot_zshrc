# https://wiki.archlinux.jp/index.php/GnuPG
if [[ -d /mnt/wslg ]]; then
    if [[ -z $GPG_AGENT_INFO ]] && (( $+commands[keychain] )); then
        # GPG_KEY_ID は git の signingkey から拾う (chezmoi 経由で Bitwarden から
        # injection 済み)。signingkey が空なら ssh agent のみで keychain を起動。
        _gpg_key_id="$(git config --global user.signingkey 2>/dev/null)"
        if [[ -n $_gpg_key_id ]]; then
            eval "$(keychain -q --eval --agents ssh,gpg "$_gpg_key_id")"
        else
            eval "$(keychain -q --eval --agents ssh)"
        fi
        unset _gpg_key_id
    fi
    typeset -gx SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
    typeset -gx GPG_TTY=$(tty)
    # M-3: gpg-connect-agent / gpg が無い環境（コンテナ等）でのエラーを抑止。
    (( $+commands[gpg-connect-agent] )) && \
        gpg-connect-agent updatestartuptty /bye > /dev/null
else
  # "GnuPG envs not loaded in zshenv"
  export GPG_TTY=$(tty)
  # Refresh gpg-agent tty in case user switches into an X session
  (( $+commands[gpg-connect-agent] )) && \
      gpg-connect-agent updatestartuptty /bye >/dev/null
fi

# L-9: `~/.config/zsh/completions` ディレクトリは廃止（未参照 + dot_zfunc/ と重複）。
#      補完は sheldon `[plugins.my_fpaths]` から `~/.config/zsh/.zfunc` のみを fpath に追加。
: "plugin manager" && {
  # ファイル名を変数に入れる
  cache_dir=${XDG_CACHE_HOME:-$HOME/.cache}
  sheldon_cache="$cache_dir/sheldon.zsh"
  sheldon_toml="$XDG_CONFIG_HOME/sheldon/plugins.toml"
  # キャッシュがない、またはキャッシュが古い場合にキャッシュを作成
  if [[ ! -r "$sheldon_cache" || "$sheldon_toml" -nt "$sheldon_cache" ]]; then
    mkdir -p $cache_dir
    sheldon source > $sheldon_cache
  fi
  source "$sheldon_cache"
  # 使い終わった変数を削除
  unset cache_dir sheldon_cache sheldon_toml
}

