################################################################################
# API tokens / Secrets (Bitwarden 経由)
################################################################################
# このファイルはインタラクティブな zsh 起動時に sheldon 経由で source される。
# `~/.zshenv` には置かない（cron / SSH コマンド / コンテナ exec などへの漏出を避ける）。

# OpenRouter (item: openrouter.CODEX)
# UUID は `chezmoi.toml.tmpl` の `[data]` 経由 (H-1) で chezmoi のローカル data に保存。
{{- if .bitwardenOpenRouterItemId }}
{{- $openrouterKey := (bitwardenFields "item" .bitwardenOpenRouterItemId).CODEX.value }}
{{- if and $openrouterKey (ne $openrouterKey "<no value>") }}
export OPENROUTER_API_KEY="{{ $openrouterKey }}"
{{- end }}
{{- end }}
