################################################################################
# API tokens / Secrets (Bitwarden 経由)
################################################################################
# このファイルはインタラクティブな zsh 起動時に sheldon 経由で source される。
# `~/.zshenv` には置かない（cron / SSH コマンド / コンテナ exec などへの漏出を避ける）。
#
# 履歴メモ:
# - 当初 `~/.zshenv` で export → C-1 で本ファイルへ移動（zshenv 経由の漏出を排除）
# - 2026-04-30 (C-1 派生): 起動時 export を廃止し `__openrouter_key` + `with_openrouter`
#   ラッパー方式に変更（`/proc/<pid>/environ` 経由の観測リスク軽減）
# - 2026-05-05: 子プロセスへの自動継承が必要なツール群（Claude Code / codex plugin /
#   GUI 起動の VSCode・nvim 等）が増えたため、export を再導入。`with_openrouter`
#   は単発注入ユースケース向けに残置。
#
# トレードオフ: export により同一 UID 配下のプロセスから `/proc/<pid>/environ` 経由で
# 観測され得る。利便性を優先した妥協。

# OpenRouter (item: openrouter.CODEX)
# UUID は `chezmoi.toml.tmpl` の `[data]` 経由 (H-1) で chezmoi のローカル data に保存。
{{- if .bitwardenOpenRouterItemId }}
{{- $openrouterKey := (bitwardenFields "item" .bitwardenOpenRouterItemId).CODEX.value }}
{{- if and $openrouterKey (ne $openrouterKey "<no value>") }}
__openrouter_key() {
  # private getter: 関数本体に値を埋め込む。直接呼ばず `with_openrouter` 経由で。
  printf '%s' '{{ $openrouterKey }}'
}

with_openrouter() {
  # 単発コマンドにだけ OPENROUTER_API_KEY を注入して実行する。
  #   例: with_openrouter codex "$@"
  #   例: with_openrouter curl https://openrouter.ai/api/v1/...
  if [[ $# -eq 0 ]]; then
    print -u2 "with_openrouter: usage: with_openrouter <command> [args...]"
    return 2
  fi
  OPENROUTER_API_KEY="$(__openrouter_key)" "$@"
}

# インタラクティブシェルで自動 export — 子プロセスへ継承させる。
export OPENROUTER_API_KEY="$(__openrouter_key)"
{{- end }}
{{- end }}

# Moonshot / Kimi (Bitwarden item "platform.kimi.ai" の main フィールドにキー本体)
# キー本体は apply 時に bitwardenFields で item の main フィールドから取得し、
# __moonshot_key() の本体に埋め込む。OpenRouter と異なり **グローバル export はしない**
# — 各ラッパーで単発注入のみ行う。
# 方針: Claude Code (素の `claude`) は本物の Claude デフォルトモデルのまま使うため、
# ANTHROPIC_* を注入する claude-kimi ラッパは置かない。
# Hermes で Kimi を使う場合は Hermes 自身の credential store にキーを登録する
# (native kimi-coding provider が解決)。__moonshot_key を source にして一度だけ:
#     print -r -- "$(__moonshot_key)" | hermes auth add kimi-coding   # 推奨: stdin、argv に載らない・listing は redacted
#     hermes config set KIMI_API_KEY "$(__moonshot_key)"              # 代替: .env 平文、値が argv=/proc/cmdline に一瞬載る
# いずれも ~/.hermes/ に平文 at-rest で残る選択 (hermes-kimi の単発注入とは逆の妥協)。
# kimi-run は Hermes 以外の OpenAI 互換ツール (OpenCode / Aider 等) 向けに残置。
{{- if index . "bitwardenMoonshotItemId" }}
{{- $moonshotKey := (bitwardenFields "item" .bitwardenMoonshotItemId).main.value }}
{{- if and $moonshotKey (ne $moonshotKey "<no value>") }}
__moonshot_key() {
  # private getter: 関数本体に値を埋め込む。直接呼ばず kimi-run 経由、または
  # Hermes へのキー登録 (hermes auth add kimi-coding / config set) の source として使う。
  printf '%s' '{{ $moonshotKey }}'
}

# Moonshot API のデフォルト設定（秘密ではない。呼び出し時に環境変数で上書き可）。
#   - 中国本土: KIMI_OPENAI_BASE を https://api.moonshot.cn/v1 に。
#   - 高速版:   KIMI_MODEL=kimi-k2.7-code-highspeed
: "${KIMI_MODEL:=kimi-k2.7-code}"
: "${KIMI_OPENAI_BASE:=https://api.moonshot.ai/v1}"

kimi-run() {
  # 任意の OpenAI 互換エージェント (Hermes / OpenCode / Aider 等) に Kimi の
  # 資格情報を単発注入して実行する。
  #   例: kimi-run hermes "$@"   /   kimi-run opencode
  # 注意: ツールによっては env ではなく独自 config でプロバイダ指定が必要。
  if [[ $# -eq 0 ]]; then
    print -u2 "kimi-run: usage: kimi-run <command> [args...]"
    return 2
  fi
  OPENAI_API_KEY="$(__moonshot_key)" \
  OPENAI_BASE_URL="$KIMI_OPENAI_BASE" \
  OPENAI_API_BASE="$KIMI_OPENAI_BASE" \
  OPENAI_MODEL="$KIMI_MODEL" \
    "$@"
}
{{- end }}
{{- end }}
