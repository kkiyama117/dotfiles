      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh repo create:*)",
      "Bash(gh pr review:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebSearch",
      "Bash(cargo check:*)",
      "Bash(uv build:*)",
      "Bash(rustup toolchain:*)",
      "Bash(rustup default:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv run:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo build:*)",
      "Bash(git push:*)",
      "Bash(wait)",
      "Bash(cargo run:*)",
      "Bash(cargo clippy *)",
      "Bash(uv pip *)",
      "Bash(cargo doc *)",
      "Bash(./scripts/build.sh data_manager_core *)",
      "Write(/home/kiyama/.claude/homunculus/instincts/personal/*.yaml)",
      "Write(/home/kiyama/.claude/homunculus/instincts/personal/*.md)",
      "Write(/home/kiyama/.claude/homunculus/projects/**/instincts/personal/*.yaml)",
      "Write(/home/kiyama/.claude/homunculus/projects/**/instincts/personal/*.md)",
      "Edit(/home/kiyama/.claude/homunculus/instincts/personal/*.yaml)",
      "Edit(/home/kiyama/.claude/homunculus/instincts/personal/*.md)",
      "Edit(/home/kiyama/.claude/homunculus/projects/**/instincts/personal/*.yaml)",
      "Edit(/home/kiyama/.claude/homunculus/projects/**/instincts/personal/*.md)",
      "Read(/home/kiyama/.claude/homunculus/**)"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-cockpit-state hook UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-cockpit-state hook PreToolUse"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-notify-hook notification"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-cockpit-state hook Notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-notify-hook stop"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-cockpit-state hook Stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/kiyama/.local/bin/claude-cockpit-state hook SessionEnd"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/kiyama/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ecc@ecc": true
  },
  "extraKnownMarketplaces": {
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      },
      "autoUpdate": true
    },
    "academic-research-skills": {
      "source": {
        "source": "github",
        "repo": "Imbad0202/academic-research-skills"
      }
    },
    "my-own-skills": {
      "source": {
        "source": "directory",
        "path": "/home/kiyama/programs/prompts/my_own_skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "editorMode": "vim",
  "verbose": true,
  "preferredNotifChannel": "kitty",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "disabledMcpJsonServers": [
    "cloudflare-docs",
    "cloudflare-workers-builds",
    "cloudflare-workers-bindings",
    "cloudflare-observability",
    "clickhouse",
    "firecrawl",
    "magic",
